{
  "name": "react-native-typescript-library-starter",
  "version": "2.0.0",
  "description": "A modern, AI-ready React Native TypeScript library starter with dual CJS/ESM output, full test setup, and developer-first tooling.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/src/index.d.ts"
    }
  },
  "source": "src/index.ts",
  "files": [
    "src",
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/WrathChaos/react-native-typescript-library-starter.git"
  },
  "author": "FreakyCoder <kurayogun@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/WrathChaos/react-native-typescript-library-starter#readme",
  "bugs": {
    "url": "https://github.com/WrathChaos/react-native-typescript-library-starter/issues"
  },
  "keywords": [
    "react-native",
    "typescript",
    "library",
    "starter",
    "template",
    "component",
    "hook",
    "ai-ready",
    "bob",
    "react-native-builder-bob"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build": "bob build",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/terminal/lint.mjs",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\"",
    "prettier": "node scripts/terminal/prettier.mjs",
    "prettier:ci": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "semantic-release": "semantic-release",
    "husky:setup": "husky"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.3.7",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "chalk": "^5.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.10",
    "metro-react-native-babel-preset": "^0.77.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "prettier": "^3.3.3",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-builder-bob": "^0.30.0",
    "react-test-renderer": "18.3.1",
    "semantic-release": "^24.1.1",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@testing-library)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.types.ts",
      "!src/**/index.ts",
      "!src/types/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
